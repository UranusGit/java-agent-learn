<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- LangChain4j 请求/响应体走 DEBUG 级别 -->
    <logger name="dev.langchain4j" level="DEBUG"/>

    <!-- LM Studio / DeepSeek HTTP 客户端日志 -->
    <logger name="dev.langchain4j.http" level="DEBUG"/>

    <!-- 屏蔽噪音 -->
    <logger name="okhttp3" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
